---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { getCollection } from 'astro:content';

const entries = await getCollection('architecture');
const projects = entries.sort((a, b) => a.data.order - b.data.order);
---

<SidebarLayout title="Architecture — Alam Alonzo" description="Architecture portfolio of Alam Alonzo. Residential, commercial, and medical projects in the Dominican Republic.">

  <!-- Sidebar -->
  <div slot="sidebar" class="sidebar-content">
    <div class="sidebar-top">
      <a href="/" class="sidebar-name">Alam Alonzo</a>
      <p class="sidebar-role" data-en="Architect · +10 yrs" data-es="Arquitecto · +10 años">Architect · +10 yrs</p>
    </div>

    <nav class="sidebar-nav">
      <a href="#projects" class="nav-link active" data-en="Projects" data-es="Proyectos">Projects</a>
      <!-- Replace href with actual PDF path when ready -->
      <a href="#" class="nav-link" data-en="CV ↓" data-es="CV ↓">CV ↓</a>
    </nav>

    <a href="/" class="back-link">← <span data-en="Back to home" data-es="Volver al inicio">Back to home</span></a>
  </div>

  <!-- Main content -->
  <div id="projects" class="projects">

    {projects.map((project) => (
      <a href={`/architecture/${project.id}`} class="project-row">

        <div class="project-info">
          <h2 class="project-title">{project.data.title}</h2>
          <p class="project-meta">{project.data.year} · {project.data.type} · {project.data.location} · {project.data.area}</p>
          <p class="project-desc">{project.data.descriptionEn[0]}</p>
          <p class="project-role">{project.data.role}</p>
        </div>

        <div class="project-photos">
          {project.data.photos.slice(0, 3).map((color) => (
            <div class="photo-thumb" style={`background:${color};`}></div>
          ))}
        </div>

      </a>
    ))}

    <!-- PM + CV footer -->
    <div class="arch-footer">
      <div class="pm-block">
        <p class="pm-label" data-en="Project Management" data-es="Project Management">Project Management</p>
        <p class="pm-text" data-en="For detailed PM work on CEDIGLO — budget management (RD$40M+), team coordination and delivery — see the full case study above." data-es="Para el trabajo de PM en CEDIGLO — gestión de presupuesto (RD$40M+), coordinación de equipo y entrega — ver el caso completo arriba.">
          For detailed PM work on CEDIGLO — budget management (RD$40M+), team coordination and delivery — see the full case study above.
        </p>
      </div>
      <div class="cv-links">
        <!-- Replace href with actual PDF paths when ready -->
        <a href="#" class="cv-btn" data-en="Download CV (EN)" data-es="Descargar CV (EN)">Download CV (EN)</a>
        <a href="#" class="cv-btn" data-en="Download CV (ES)" data-es="Descargar CV (ES)">Download CV (ES)</a>
        <a href="#" class="cv-btn" data-en="Download PM CV" data-es="Descargar CV PM">Download PM CV</a>
      </div>
    </div>

  </div>

</SidebarLayout>

<style>
  /* ── Sidebar content ── */
  .sidebar-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 2rem;
  }

  .sidebar-top {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.01em;
  }

  .sidebar-name:hover { color: #2563eb; }

  .sidebar-role {
    font-size: 0.7rem;
    color: #9ca3af;
    letter-spacing: 0.04em;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid #f3f4f6;
    border-bottom: 1px solid #f3f4f6;
    padding: 1rem 0;
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 400;
    color: #6b7280;
    transition: color 0.15s;
    letter-spacing: 0.02em;
  }

  .nav-link:hover,
  .nav-link.active { color: #111827; }

  .back-link {
    font-size: 0.75rem;
    color: #9ca3af;
    transition: color 0.15s;
    margin-top: auto;
  }

  .back-link:hover { color: #374151; }

  /* Mobile sidebar horizontal */
  @media (max-width: 768px) {
    .sidebar-content {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
      height: auto;
    }

    .sidebar-nav {
      flex-direction: row;
      border: none;
      padding: 0;
      gap: 1rem;
    }

    .back-link { margin-top: 0; }
    .sidebar-role { display: none; }
  }

  /* ── Projects list ── */
  .projects {
    display: flex;
    flex-direction: column;
    max-width: 760px;
    margin: 0 auto;
  }

  .project-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1.6rem;
    padding: 2rem 0;
    border-bottom: 1px solid #f3f4f6;
    cursor: pointer;
    transition: background 0.15s;
    border-radius: 6px;
    margin: 0 -0.75rem;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  .project-row:first-child { padding-top: 0; }

  .project-row:hover {
    background: #fafafa;
  }

  .project-row:hover .photo-thumb {
    transform: scale(1.04);
  }

  /* Project info */
  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
    max-width: 420px;
  }

  .project-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .project-meta {
    font-size: 0.72rem;
    color: #9ca3af;
    letter-spacing: 0.02em;
  }

  .project-desc {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.55;
    max-width: 38ch;
  }

  .project-role {
    font-size: 0.7rem;
    color: #9ca3af;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Project photos */
  .project-photos {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .photo-thumb {
    width: 80px;
    height: 80px;
    border-radius: 4px;
    border: 1px solid #e5e7eb;
    transition: transform 0.2s ease;
    flex-shrink: 0;
  }

  /* ── Footer ── */
  .arch-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px dotted #d1d5db;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .pm-label {
    font-size: 0.65rem;
    font-weight: 600;
    color: #9ca3af;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .pm-text {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.6;
    max-width: 52ch;
  }

  .cv-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cv-btn {
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.4rem 0.9rem;
    transition: border-color 0.15s, color 0.15s;
    letter-spacing: 0.01em;
  }

  .cv-btn:hover {
    border-color: #9ca3af;
    color: #111827;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .project-row {
      flex-direction: column;
    }

    .project-photos {
      width: 100%;
    }

    .photo-thumb {
      flex: 1;
      height: 70px;
    }
  }
</style>
