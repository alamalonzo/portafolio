---
import SidebarLayout from '../../layouts/SidebarLayout.astro';
import { getCollection } from 'astro:content';
import { bio } from '../../data/bio';

const entries = await getCollection('architecture');
const projects = entries.sort((a, b) => a.data.order - b.data.order);
---

<SidebarLayout title="Architecture — Alam Alonzo" description="Architecture portfolio of Alam Alonzo. Residential, commercial, and medical projects in the Dominican Republic.">

  <!-- Language toggle -->
  <div id="lang-toggle" class="lang-toggle">
    <button data-lang="en" class="active">EN</button>
    <span>|</span>
    <button data-lang="es">ES</button>
  </div>

  <!-- Sidebar -->
  <div slot="sidebar" class="sidebar-content">
    <div class="sidebar-top">
      <a href="/" class="sidebar-name">Alam Alonzo</a>
      <p class="sidebar-role" data-en="Architect · +10 yrs" data-es="Arquitecto · +10 años">Architect · +10 yrs</p>
    </div>

    <nav class="sidebar-nav">
      <a href="#projects" class="nav-link active" data-en="Projects" data-es="Proyectos">Projects</a>
      <a href="/pdfs/cv-2026-en.pdf" download class="nav-link" data-en="CV ↓" data-es="CV ↓">CV ↓</a>
      <a href="/pdfs/portafolio-2026-en.pdf" data-href-en="/pdfs/portafolio-2026-en.pdf" data-href-es="/pdfs/portafolio-2026-es.pdf" download class="nav-link" data-en="Portfolio ↓" data-es="Portafolio ↓">Portfolio ↓</a>
    </nav>

    <a href="/" class="back-link">← <span data-en="Back to home" data-es="Volver al inicio">Back to home</span></a>

    <div class="sidebar-social">
      <a href="https://x.com/alamalonzo" target="_blank" rel="noopener noreferrer" aria-label="X" class="social-icon social-x">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.748l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://instagram.com/alamalonzo" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="social-icon social-ig">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://linkedin.com/in/alamalonzo" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="social-icon social-li">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="white"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
      </a>
    </div>
  </div>

  <!-- Main content -->
  <div id="projects" class="projects">

    <!-- Bio block -->
    <div class="arch-bio">
      {bio.en.map((para, i) => (
        <p data-en={para} data-es={bio.es[i]}>{para}</p>
      ))}
    </div>

    {projects.map((project) => (
      <a href={`/architecture/${project.id}`} class="project-row">

        <div class="project-info">
          <h2 class="project-title">{project.data.title}</h2>
          <p class="project-meta" data-en={`${project.data.year} · ${project.data.type} · ${project.data.location} · ${project.data.area}`} data-es={`${project.data.year} · ${project.data.typeEs || project.data.type} · ${project.data.locationEs || project.data.location} · ${project.data.area}`}>{project.data.year} · {project.data.type} · {project.data.location} · {project.data.area}</p>
          <p class="project-desc" data-en={project.data.resumen} data-es={project.data.resumenEs || project.data.resumen}>{project.data.resumen}</p>
          <p class="project-role" data-en={project.data.role} data-es={project.data.roleEs || project.data.role}>{project.data.role}</p>
        </div>

        <div class="project-photos">
          {(() => {
            const p = project.data.photos[0];
            return p.startsWith('/')
              ? <img src={p} alt={project.data.title} class="photo-main" />
              : <div class="photo-main" style={`background:${p};`}></div>;
          })()}
        </div>

      </a>
    ))}

    <!-- CV + Portafolio footer -->
    <div class="arch-footer">
      <div class="cv-links">
        <a href="/pdfs/cv-2026-en.pdf" download class="cv-btn" data-en="Download CV (EN)" data-es="Descargar CV (EN)">Download CV (EN)</a>
        <a href="/pdfs/portafolio-2026-en.pdf" data-href-en="/pdfs/portafolio-2026-en.pdf" data-href-es="/pdfs/portafolio-2026-es.pdf" download class="cv-btn" data-en="Download Portfolio" data-es="Descargar Portafolio">Download Portfolio</a>
      </div>
    </div>

  </div>

</SidebarLayout>

<style>
  /* ── Sidebar content ── */
  .sidebar-content {
    display: flex;
    flex-direction: column;
    height: 100%;
    gap: 2rem;
  }

  .sidebar-top {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .sidebar-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.01em;
  }

  .sidebar-name:hover { color: #2563eb; }

  .sidebar-role {
    font-size: 0.7rem;
    color: #9ca3af;
    letter-spacing: 0.04em;
  }

  .sidebar-nav {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    border-top: 1px solid #f3f4f6;
    border-bottom: 1px solid #f3f4f6;
    padding: 1rem 0;
  }

  .nav-link {
    font-size: 0.8rem;
    font-weight: 400;
    color: #6b7280;
    transition: color 0.15s;
    letter-spacing: 0.02em;
  }

  .nav-link:hover,
  .nav-link.active { color: #111827; }

  .back-link {
    font-size: 0.75rem;
    color: #9ca3af;
    transition: color 0.15s;
  }

  .back-link:hover { color: #374151; }

  /* Sidebar social icons */
  .sidebar-social {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-top: auto;
    flex-wrap: wrap;
  }

  .social-icon {
    width: 22px;
    height: 22px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: opacity 0.15s;
  }

  .social-icon:hover { opacity: 0.8; }

  .social-x  { background: #000; }
  .social-ig { background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888); }
  .social-tt { background: #010101; }
  .social-li { background: #0a66c2; }

  /* Language toggle */
  .lang-toggle {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.2rem;
    z-index: 100;
  }

  .lang-toggle span { color: #d1d5db; font-size: 0.65rem; }

  .lang-toggle button {
    background: none;
    border: none;
    color: #9ca3af;
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.3rem;
    cursor: pointer;
    transition: color 0.15s;
  }

  .lang-toggle button.active { color: #374151; }
  .lang-toggle button:hover:not(.active) { color: #374151; }

  /* Mobile sidebar horizontal */
  @media (max-width: 768px) {
    .sidebar-content {
      flex-direction: row;
      align-items: center;
      gap: 1.5rem;
      height: auto;
    }

    .sidebar-nav {
      flex-direction: row;
      border: none;
      padding: 0;
      gap: 1rem;
    }

    .back-link { display: none; }
    .sidebar-social { display: none; }
    .sidebar-role { display: none; }
  }

  /* ── Bio block ── */
  .arch-bio {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 2.5rem;
    border-bottom: 1px dotted #d1d5db;
    margin-bottom: 0;
  }

  .arch-bio p {
    font-size: 0.95rem;
    color: #6b7280;
    line-height: 1.75;
    max-width: 54ch;
    font-weight: 300;
  }

  /* ── Projects list ── */
  .projects {
    display: flex;
    flex-direction: column;
    max-width: 760px;
    margin: 0 auto;
  }

  .project-row {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1.6rem;
    padding: 2rem 0;
    border-bottom: 1px solid #f3f4f6;
    cursor: pointer;
    transition: background 0.15s;
    border-radius: 6px;
    margin: 0 -0.75rem;
    padding-left: 0.75rem;
    padding-right: 0.75rem;
  }

  .project-row:first-child { padding-top: 0; }

  .project-row:hover {
    background: #fafafa;
  }


  /* Project info */
  .project-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
    min-width: 0;
    max-width: 420px;
  }

  .project-title {
    font-size: 1.05rem;
    font-weight: 600;
    color: #111827;
    letter-spacing: -0.01em;
    line-height: 1.2;
  }

  .project-meta {
    font-size: 0.72rem;
    color: #9ca3af;
    letter-spacing: 0.02em;
  }

  .project-desc {
    font-size: 0.85rem;
    color: #6b7280;
    line-height: 1.55;
    max-width: 38ch;
  }

  .project-role {
    font-size: 0.7rem;
    color: #9ca3af;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* Project photos */
  .project-photos {
    flex-shrink: 0;
  }

  .photo-main {
    width: 200px;
    aspect-ratio: 1188 / 725;
    border-radius: 6px;
    border: 1px solid #e5e7eb;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }

  .project-row:hover .photo-main {
    transform: scale(1.02);
  }

  /* ── Footer ── */
  .arch-footer {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px dotted #d1d5db;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .cv-links {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .cv-btn {
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.4rem 0.9rem;
    transition: border-color 0.15s, color 0.15s;
    letter-spacing: 0.01em;
  }

  .cv-btn:hover {
    border-color: #9ca3af;
    color: #111827;
  }

  /* Mobile adjustments */
  @media (max-width: 640px) {
    .project-row {
      flex-direction: column;
    }

    .project-photos {
      width: 100%;
    }

    .photo-main {
      width: 100%;
    }
  }
</style>
