---
import DetailLayout from '../../layouts/DetailLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('architecture');
  const projects = entries.sort((a, b) => a.data.order - b.data.order);
  return projects.map((entry, i) => ({
    params: { slug: entry.id },
    props: {
      entry,
      prev: projects[i - 1] ? { ...projects[i - 1].data, slug: projects[i - 1].id } : null,
      next: projects[i + 1] ? { ...projects[i + 1].data, slug: projects[i + 1].id } : null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const project = entry.data;
const { Content } = await render(entry);
---

<DetailLayout
  title={`${project.title} — Alam Alonzo`}
  description={project.resumen}
>

  <!-- Back link -->
  <a href="/architecture" class="back">
    <span data-en="← Architecture" data-es="← Arquitectura">← Architecture</span>
  </a>

  <!-- Header -->
  <header class="project-header">
    <h1 class="project-title">{project.title}</h1>
    <p class="project-meta" data-en={`${project.type} · ${project.year} · ${project.location} · ${project.area}`} data-es={`${project.typeEs || project.type} · ${project.year} · ${project.locationEs || project.location} · ${project.area}`}>{project.type} · {project.year} · {project.location} · {project.area}</p>
  </header>

  <!-- Hero image slider -->
  <div class="hero-slider" id="hero-slider">
    {project.photos.map((photo, i) => (
      photo.startsWith('/')
        ? <img src={photo} alt={`${project.title} ${i + 1}`} class={`slide${i === 0 ? ' active' : ''}`} data-index={i} />
        : <div class={`slide${i === 0 ? ' active' : ''}`} style={`background:${photo};`} data-index={i}></div>
    ))}
    <button class="slider-btn slider-prev" id="slider-prev" aria-label="Previous">&#8592;</button>
    <button class="slider-btn slider-next" id="slider-next" aria-label="Next">&#8594;</button>
  </div>
  <div class="slider-dots" id="slider-dots">
    {project.photos.map((_, i) => (
      <button class={`dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Go to slide ${i + 1}`}></button>
    ))}
  </div>

  <script>
    const slider = document.getElementById('hero-slider');
    const dotsContainer = document.getElementById('slider-dots');
    if (slider && dotsContainer) {
      const slides = slider.querySelectorAll<HTMLElement>('.slide');
      const dots = dotsContainer.querySelectorAll<HTMLElement>('.dot');
      let current = 0;

      function goTo(n: number) {
        slides[current].classList.remove('active');
        dots[current].classList.remove('active');
        current = (n + slides.length) % slides.length;
        slides[current].classList.add('active');
        dots[current].classList.add('active');
      }

      document.getElementById('slider-prev')?.addEventListener('click', () => goTo(current - 1));
      document.getElementById('slider-next')?.addEventListener('click', () => goTo(current + 1));
      dots.forEach((dot) => {
        dot.addEventListener('click', () => goTo(Number(dot.dataset.index)));
      });
    }
  </script>

  <!-- Overview: specs + description -->
  <div class="overview">
    <div class="specs">
      <div class="spec-row">
        <span class="spec-label" data-en="Area" data-es="Área">Area</span>
        <span class="spec-value">{project.area}</span>
      </div>
      <div class="spec-row">
        <span class="spec-label" data-en="Year" data-es="Año">Year</span>
        <span class="spec-value">{project.year}</span>
      </div>
      <div class="spec-row">
        <span class="spec-label" data-en="Location" data-es="Ubicación">Location</span>
        <span class="spec-value" data-en={project.location} data-es={project.locationEs || project.location}>{project.location}</span>
      </div>
      {project.budget && (
        <div class="spec-row">
          <span class="spec-label" data-en="Budget" data-es="Presupuesto">Budget</span>
          <span class="spec-value">{project.budget}</span>
        </div>
      )}
      <div class="spec-row">
        <span class="spec-label" data-en="Duration" data-es="Duración">Duration</span>
        <span class="spec-value" data-en={project.duration} data-es={project.durationEs || project.duration}>{project.duration}</span>
      </div>
      <div class="spec-row">
        <span class="spec-label" data-en="Status" data-es="Estado">Status</span>
        <span class="spec-value" data-en={project.status} data-es={project.statusEs || project.status}>{project.status}</span>
      </div>
      <div class="spec-row">
        <span class="spec-label" data-en="Role" data-es="Rol">Role</span>
        <span class="spec-value" data-en={project.role} data-es={project.roleEs || project.role}>{project.role}</span>
      </div>
    </div>

    <div class="description">
      {project.descriptionEn
        ? project.descriptionEn.map((para, i) => (
            <p data-en={para} data-es={project.descriptionEs?.[i] ?? para}>{para}</p>
          ))
        : <Content />
      }
    </div>
  </div>

  <!-- Skills & Tools -->
  {project.skills && project.skills.length > 0 && (
    <div class="skills-section">
      <p class="skills-label" data-en="Skills & Tools" data-es="Habilidades y Herramientas">Skills & Tools</p>
      <div class="skills-list">
        {project.skills.map(skill => <span class="skill-tag">{skill}</span>)}
      </div>
    </div>
  )}

  <!-- Photo gallery -->
  {(() => {
    const galleryPhotos = project.gallery ?? project.photos.slice(0, 4);
    const renderPhoto = (photo: string, cls: string, alt: string) =>
      photo.startsWith('/')
        ? <img src={photo} alt={alt} class={cls} />
        : <div class={cls} style={`background:${photo};`}></div>;
    return (
      <div class="gallery">
        {renderPhoto(galleryPhotos[0], 'gallery-main', project.title)}
        <div class="gallery-row">
          {galleryPhotos.slice(1, 3).map((p, i) => renderPhoto(p, 'gallery-half', `${project.title} ${i + 2}`))}
        </div>
        {galleryPhotos.length > 3 && (
          <div class="gallery-row">
            {galleryPhotos.slice(3).map((p, i) => renderPhoto(p, 'gallery-half', `${project.title} ${i + 4}`))}
          </div>
        )}
      </div>
    );
  })()}

  <!-- Results (only if available) -->
  {project.results && project.results.length > 0 && (
    <div class="results">
      {project.results.map((r) => (
        <div class="result-item">
          <span class="result-value">{r.value}</span>
          <span class="result-label">{r.label}</span>
        </div>
      ))}
    </div>
  )}

  <!-- PM section (Centro Médico MMB only) -->
  {project.isPM && (
    <div class="pm-section">
      <p class="pm-eyebrow" data-en="Project Management" data-es="Project Management">Project Management</p>
      <h2 class="pm-title" data-en="Beyond architecture" data-es="Más allá de la arquitectura">Beyond architecture</h2>
      <div class="pm-body">
        <p data-en="Centro Médico MMB was my most complex project management challenge. I was responsible for the full delivery lifecycle: assembling the consultant team, writing and negotiating contracts, building and tracking a RD$40M+ budget, and resolving field conflicts between structural, MEP, and architectural work in real time." data-es="Centro Médico MMB fue mi reto más complejo de project management. Fui responsable del ciclo completo de entrega: armar el equipo de consultores, redactar y negociar contratos, construir y dar seguimiento a un presupuesto de RD$40M+, y resolver conflictos en campo entre los trabajos estructurales, MEP y arquitectónicos en tiempo real.">
          Centro Médico MMB was my most complex project management challenge. I was responsible for the full delivery lifecycle: assembling the consultant team, writing and negotiating contracts, building and tracking a RD$40M+ budget, and resolving field conflicts between structural, MEP, and architectural work in real time.
        </p>
        <p data-en="The project was delivered on schedule. Download my full PM CV for detail on methodology, tools, and team structure." data-es="El proyecto fue entregado en tiempo. Descarga mi CV de PM completo para detalles sobre metodología, herramientas y estructura del equipo.">
          The project was delivered on schedule. Download my full PM CV for detail on methodology, tools, and team structure.
        </p>
      </div>
      <a href="#" class="pm-cv-btn" data-en="Download PM CV" data-es="Descargar CV PM">Download PM CV</a>
    </div>
  )}

  <!-- Project navigation -->
  <nav class="proj-nav">
    {prev ? (
      <a href={`/architecture/${prev.slug}`} class="proj-nav-link prev">
        <span class="proj-nav-dir" data-en="← Previous" data-es="← Anterior">← Previous</span>
        <span class="proj-nav-title">{prev.title}</span>
      </a>
    ) : <span />}
    {next ? (
      <a href={`/architecture/${next.slug}`} class="proj-nav-link next">
        <span class="proj-nav-dir" data-en="Next →" data-es="Siguiente →">Next →</span>
        <span class="proj-nav-title">{next.title}</span>
      </a>
    ) : <span />}
  </nav>

  <!-- Lang toggle -->
  <div id="lang-toggle" class="lang-toggle">
    <button data-lang="en" class="active">EN</button>
    <span>|</span>
    <button data-lang="es">ES</button>
  </div>

</DetailLayout>

<style>
  .back {
    display: inline-block;
    font-size: 0.75rem;
    color: #9ca3af;
    letter-spacing: 0.04em;
    margin-bottom: 2rem;
    transition: color 0.15s;
  }
  .back:hover { color: #374151; }

  .project-header { margin-bottom: 2rem; }

  .project-title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111827;
    line-height: 1.1;
    margin-bottom: 0.5rem;
  }

  .project-meta {
    font-size: 0.75rem;
    color: #9ca3af;
    letter-spacing: 0.04em;
  }

  /* ── Hero slider ── */
  .hero-slider {
    position: relative;
    width: 100%;
    aspect-ratio: 1188 / 725;
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid #e5e7eb;
  }

  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.4s ease;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .slide.active { opacity: 1; }

  .slider-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: rgba(255, 255, 255, 0.85);
    border: 1px solid #e5e7eb;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    color: #374151;
    cursor: pointer;
    transition: background 0.15s, opacity 0.15s;
    z-index: 10;
    line-height: 1;
  }

  .slider-btn:hover { background: #fff; }

  .slider-prev { left: 0.75rem; }
  .slider-next { right: 0.75rem; }

  .slider-dots {
    display: flex;
    gap: 0.4rem;
    justify-content: center;
    margin-top: 0.75rem;
    margin-bottom: 2.25rem;
  }

  .dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #d1d5db;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }

  .dot.active { background: #374151; }

  /* hero-slider uses aspect-ratio, no height override needed on mobile */

  .overview {
    display: grid;
    grid-template-columns: 180px 1fr;
    gap: 2rem 3rem;
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #f3f4f6;
  }

  @media (max-width: 640px) {
    .overview { grid-template-columns: 1fr; gap: 2rem; }
  }

  .specs { display: flex; flex-direction: column; gap: 0.75rem; }

  .spec-row { display: flex; flex-direction: column; gap: 0.1rem; }

  .spec-label {
    font-size: 0.62rem;
    font-weight: 600;
    color: #9ca3af;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .spec-value { font-size: 0.85rem; color: #374151; }

  .description { display: flex; flex-direction: column; gap: 1rem; }

  .description p { font-size: 0.95rem; color: #374151; line-height: 1.75; }

  /* ── Skills & Tools ── */
  .skills-section {
    margin-bottom: 3rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid #f3f4f6;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .skills-label {
    font-size: 0.62rem;
    font-weight: 600;
    color: #9ca3af;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .skills-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill-tag {
    font-size: 0.75rem;
    color: #374151;
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    letter-spacing: 0.01em;
    white-space: nowrap;
  }

  .gallery { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 3rem; }

  .gallery-main {
    width: 100%;
    aspect-ratio: 1188 / 725;
    border-radius: 6px;
    border: 1px solid #e5e7eb;
  }

  .gallery-row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; }

  .gallery-half { aspect-ratio: 1188 / 725; border-radius: 6px; border: 1px solid #e5e7eb; object-fit: cover; width: 100%; }
  .gallery-main { object-fit: cover; width: 100%; }

  /* gallery uses aspect-ratio, scales naturally on mobile */

  .results {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
    gap: 1.5rem;
    padding: 2rem 0;
    margin-bottom: 3rem;
    border-top: 1px dotted #d1d5db;
    border-bottom: 1px dotted #d1d5db;
  }

  .result-item { display: flex; flex-direction: column; gap: 0.25rem; }

  .result-value {
    font-size: 1.5rem;
    font-weight: 700;
    color: #111827;
    letter-spacing: -0.02em;
    line-height: 1;
  }

  .result-label { font-size: 0.7rem; color: #9ca3af; letter-spacing: 0.04em; }

  .pm-section {
    background: #fafafa;
    border: 1px solid #f3f4f6;
    border-radius: 8px;
    padding: 2rem;
    margin-bottom: 3rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .pm-eyebrow {
    font-size: 0.62rem;
    font-weight: 600;
    color: #9ca3af;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .pm-title { font-size: 1.25rem; font-weight: 600; color: #111827; letter-spacing: -0.01em; }

  .pm-body { display: flex; flex-direction: column; gap: 0.75rem; }

  .pm-body p { font-size: 0.9rem; color: #6b7280; line-height: 1.7; }

  .pm-cv-btn {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 500;
    color: #374151;
    border: 1px solid #e5e7eb;
    border-radius: 6px;
    padding: 0.4rem 0.9rem;
    transition: border-color 0.15s, color 0.15s;
    align-self: flex-start;
  }

  .pm-cv-btn:hover { border-color: #9ca3af; color: #111827; }

  .proj-nav {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding-top: 2rem;
    border-top: 1px solid #f3f4f6;
    gap: 1rem;
  }

  .proj-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    max-width: 45%;
    transition: opacity 0.15s;
  }

  .proj-nav-link:hover { opacity: 0.65; }
  .proj-nav-link.next { text-align: right; margin-left: auto; }

  .proj-nav-dir { font-size: 0.7rem; color: #9ca3af; letter-spacing: 0.04em; }
  .proj-nav-title { font-size: 0.9rem; font-weight: 500; color: #111827; }

  .lang-toggle {
    position: fixed;
    top: 1rem;
    right: 1.25rem;
    display: flex;
    align-items: center;
    gap: 0.2rem;
    z-index: 100;
  }

  .lang-toggle span { color: #d1d5db; font-size: 0.65rem; }

  .lang-toggle button {
    background: none;
    border: none;
    color: #9ca3af;
    font-family: var(--font-body);
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.3rem;
    transition: color 0.15s;
  }

  .lang-toggle button.active { color: #374151; }
  .lang-toggle button:hover:not(.active) { color: #374151; }
</style>
