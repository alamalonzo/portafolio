---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alam Alonzo',
  description = 'Architect. iOS Developer. Project Manager. Santo Domingo, Dominican Republic.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Set lang early to avoid flash -->
    <script is:inline>
      (function () {
        var lang = localStorage.getItem('lang') || 'en';
        document.documentElement.lang = lang;
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<script>
  function applyLang(lang: string) {
    document.documentElement.lang = lang;
    document.querySelectorAll<HTMLElement>('[data-en]').forEach((el) => {
      const text = lang === 'es' ? el.dataset.es : el.dataset.en;
      if (text !== undefined) el.textContent = text;
    });
    document.querySelectorAll<HTMLButtonElement>('#lang-toggle button').forEach((btn) => {
      btn.classList.toggle('active', btn.dataset.lang === lang);
    });
    // Toggle feature lists (EN/ES)
    document.querySelectorAll<HTMLElement>('.features-en').forEach((el) => {
      el.style.display = lang === 'en' ? '' : 'none';
    });
    document.querySelectorAll<HTMLElement>('.features-es').forEach((el) => {
      el.style.display = lang === 'es' ? '' : 'none';
    });
    localStorage.setItem('lang', lang);
  }

  // Apply on load
  applyLang(localStorage.getItem('lang') || 'en');

  // Wire up toggle buttons
  document.querySelectorAll<HTMLButtonElement>('#lang-toggle button').forEach((btn) => {
    btn.addEventListener('click', () => applyLang(btn.dataset.lang!));
  });
</script>
